<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 通达信选股系统</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    
    <style>
        :root {
            --bs-body-font-size: 0.875rem;
            --bs-body-font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", "Noto Sans", "Liberation Sans", Arial, sans-serif;
            --navbar-height: 56px;
            --sidebar-width: 240px;
        }
        
        body {
            min-height: 100vh;
        }

        /* 顶部 Navbar - Bootstrap Dashboard 风格 */
        .navbar {
            background-color: #212529;
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
            height: var(--navbar-height);
        }
        
        .navbar-brand {
            font-weight: 600;
            color: white !important;
        }

        /* 侧边栏 */
        .sidebar {
            position: fixed;
            top: var(--navbar-height);
            bottom: 0;
            left: 0;
            z-index: 100;
            padding-top: 1rem;
            background-color: #f8f9fa;
            box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1);
            width: var(--sidebar-width);
            overflow-y: auto;
        }

        .sidebar-sticky {
            height: calc(100vh - var(--navbar-height));
            overflow-x: hidden;
            overflow-y: auto;
            padding-bottom: 1rem;
        }

        .sidebar .nav-link {
            font-weight: 500;
            color: #212529;
            padding: 0.75rem 1rem;
            margin: 0.125rem 0.5rem;
            border-radius: 0.375rem;
        }

        .sidebar .nav-link:hover {
            background-color: #e9ecef;
            color: #0d6efd;
        }

        .sidebar .nav-link.active {
            background-color: #0d6efd;
            color: white;
        }

        .sidebar .nav-link i {
            margin-right: 0.5rem;
            width: 1rem;
            text-align: center;
        }

        /* 主内容区域 */
        main {
            margin-left: var(--sidebar-width);
            padding: 1.5rem;
            padding-top: calc(var(--navbar-height) + 0.5rem); /* 56px + 8px = 64px，与左侧保持一致 */
            background-color: #f8f9fa;
            min-height: 100vh;
        }

        /* 页面标题 */
        .page-header {
            margin-top: 0;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #dee2e6;
        }

        /* 数据卡片 */
        .data-card {
            background: white;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
            border: 1px solid rgba(0,0,0,0.125);
            height: calc(100vh - var(--navbar-height) - 100px);
            display: flex;
            flex-direction: column;
        }

        .data-card-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid rgba(0,0,0,0.125);
            background: #f8f9fa;
        }

        .data-card-header h5 {
            margin: 0;
            font-weight: 600;
            color: #212529;
        }

        .data-card-body {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        /* 数据表格 */
        .data-table {
            margin-bottom: 0;
            font-size: 0.875rem;
        }

        .data-table thead th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid #dee2e6;
            white-space: nowrap;
            padding: 0.75rem 1rem;
        }

        .data-table tbody td {
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }

        .data-table tbody tr:hover {
            background-color: #f8f9fa;
        }

        .stock-code {
            font-family: 'Courier New', monospace;
            font-weight: 600;
            color: #0d6efd;
        }

        .badge-count {
            background-color: #0d6efd;
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 50rem;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* 空状态 */
        .empty-state {
            padding: 3rem 1rem;
            text-align: center;
            color: #6c757d;
        }

        .empty-state i {
            font-size: 3rem;
            opacity: 0.5;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- 顶部 Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-graph-up-arrow me-2"></i>
                通达信选股系统
            </a>
        </div>
    </nav>

    <!-- 主体布局 -->
    <div class="container-fluid">
        <div class="row">
            <!-- 左侧导航 -->
            <nav class="sidebar">
                <div class="sidebar-sticky">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link @((ViewData["ActivePage"]?.ToString() == "Home") ? "active" : "")" asp-page="/Index">
                                <i class="bi bi-house-door"></i>
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @((ViewData["ActivePage"]?.ToString() == "B01") ? "active" : "")" asp-page="/Index/B01">
                                <i class="bi bi-file-earmark-bar-graph"></i>
                                B01_长线
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @((ViewData["ActivePage"]?.ToString() == "B02") ? "active" : "")" asp-page="/Index/B02">
                                <i class="bi bi-file-earmark-bar-graph"></i>
                                B02_长线
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @((ViewData["ActivePage"]?.ToString() == "BA1") ? "active" : "")" asp-page="/Index/BA1">
                                <i class="bi bi-file-earmark-bar-graph"></i>
                                BA1_短线
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @((ViewData["ActivePage"]?.ToString() == "BA2") ? "active" : "")" asp-page="/Index/BA2">
                                <i class="bi bi-file-earmark-bar-graph"></i>
                                BA2_短线
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- 右侧内容 -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
