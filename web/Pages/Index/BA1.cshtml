@page
@model web.Pages.Index.BA1Model
@{
    ViewData["Title"] = "BA1 短线数据";
    ViewData["ActivePage"] = "BA1";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">BA1 短线数据</h1>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="data-card">
            <div class="data-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5>📋 BA1</h5>
                    <small class="text-muted">短线日报 - AAA 选股池 - 低档金叉</small>
                </div>
                <span class="badge-count">@Model.BA1Count 条</span>
            </div>
            <div class="data-card-body">
                @if (Model.BA1Stocks.Any())
                {
                    <table class="table data-table">
                        <thead><tr><th>代码</th><th>名称</th><th>记录日期</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.BA1Stocks)
                            {
                                <tr>
                                    <td class="stock-code">@s.StockCode</td><td>@s.StockName</td>
                                    <td>@s.RecordDateCst</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-inbox"></i><p class="mt-3">暂无数据</p></div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="data-card">
            <div class="data-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5>🆕 BA1_DELTA</h5>
                    <small class="text-muted">短线新增 - AAA 选股池 - 低档金叉</small>
                </div>
                <span class="badge-count">@Model.BA1DeltaCount 条</span>
            </div>
            <div class="data-card-body">
                @if (Model.BA1DeltaStocks.Any())
                {
                    <table class="table data-table">
                        <thead><tr><th>代码</th><th>名称</th><th>入选日期</th><th class="text-end">买点</th><th>记录日期</th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.BA1DeltaStocks)
                            {
                                <tr>
                                    <td class="stock-code">@s.StockCode</td><td>@s.StockName</td>
                                    <td>@s.EntryDateCst</td>
                                    <td class="text-end">@s.BuyPoint?.ToString("F2")</td>
                                    <td>@s.RecordDateCst</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-inbox"></i><p class="mt-3">暂无数据</p></div>
                }
            </div>
        </div>
    </div>
</div>
