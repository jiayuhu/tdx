@page
@model web.Pages.Index.B01Model
@{
    ViewData["Title"] = "B01 长线数据";
    ViewData["ActivePage"] = "B01";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">B01 长线数据</h1>
</div>

<div class="row g-4">
    <!-- 左侧：B01 数据 -->
    <div class="col-lg-6">
        <div class="data-card">
            <div class="data-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5>📋 B01</h5>
                    <small class="text-muted">长线日报 - 优质小盘股 - 低档金叉</small>
                </div>
                <span class="badge-count">@Model.B01Count 条</span>
            </div>
            <div class="data-card-body">
                @if (Model.B01Stocks.Any())
                {
                    <table class="table data-table">
                        <thead>
                            <tr>
                                <th>代码</th>
                                <th>名称</th>
                                <th>记录日期</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stock in Model.B01Stocks)
                            {
                                <tr>
                                    <td class="stock-code">@stock.StockCode</td>
                                    <td>@stock.StockName</td>
                                    <td>@stock.RecordDateCst</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p class="mt-3">暂无数据</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 右侧：B01_DELTA 数据 -->
    <div class="col-lg-6">
        <div class="data-card">
            <div class="data-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5>🆕 B01_DELTA</h5>
                    <small class="text-muted">长线新增 - 优质小盘股 - 低档金叉</small>
                </div>
                <span class="badge-count">@Model.B01DeltaCount 条</span>
            </div>
            <div class="data-card-body">
                @if (Model.B01DeltaStocks.Any())
                {
                    <table class="table data-table">
                        <thead>
                            <tr>
                                <th>代码</th>
                                <th>名称</th>
                                <th>入选日期</th>
                                <th class="text-end">买点</th>
                                <th>记录日期</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.B01DeltaStocks)
                            {
                                <tr>
                                    <td class="stock-code">@s.StockCode</td>
                                    <td>@s.StockName</td>
                                    <td>@s.EntryDateCst</td>
                                    <td class="text-end">@s.BuyPoint?.ToString("F2")</td>
                                    <td>@s.RecordDateCst</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p class="mt-3">暂无数据</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
